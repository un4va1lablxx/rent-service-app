{
  "expo": {
    "name": "mobile-client",
    "slug": "mobile-client",
    "scheme": "rentservice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {},
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложению нужен доступ к фото, чтобы загрузить фотографии жилья и документы для проверки.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ]
  }
}
